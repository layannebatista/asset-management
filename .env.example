# =============================================================================
# Template de variáveis de ambiente
# Copie para .env e preencha com seus valores reais:
#   cp .env.example .env
# =============================================================================

# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5433/asset_management
DB_USERNAME=asset_user
DB_PASSWORD=CHANGE_ME

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_min_64_chars

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
# Login SMTP do Brevo: Settings → SMTP & API → aba SMTP → campo "Login"
# Exemplo: a61088001@smtp-brevo.com
MAIL_USERNAME=CHANGE_ME@smtp-brevo.com
# Chave SMTP do Brevo (coluna "Key" na aba SMTP)
MAIL_PASSWORD=CHANGE_ME
# Deve ser um remetente verificado em: Settings → Senders & IP → Senders
MAIL_FROM=CHANGE_ME@gmail.com

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
TEST_DATA_CLEANUP_ENABLED=true
TEST_DATA_CLEANUP_KEY=CHANGE_ME_CLEANUP_KEY

# ─── Vite (build-arg do Docker; URL que o browser usa para chamar a API) ──────
# /api → proxy reverso do Vite (npm run dev) ou do Nginx (Docker) → backend
VITE_API_URL=/api

# ─── Grafana (apenas para Docker Compose) ────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# ─── AI Intelligence Service ──────────────────────────────────────────────────
# Internal API key for service-to-service calls (backend → ai-intelligence)
# Generate with: openssl rand -hex 32
AI_SERVICE_API_KEY=CHANGE_ME_random_32_char_hex

# OpenAI API key – required for all AI features
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# GitHub – for CI/CD pipeline analysis (repo:read scope only)
GITHUB_TOKEN=CHANGE_ME
GITHUB_OWNER=CHANGE_ME
GITHUB_REPO=CHANGE_ME

# Spring Boot – URL that the Java backend uses to call the AI service internally
AI_SERVICE_URL=http://ai-intelligence:3100

# Credenciais de admin usadas pelos testes E2E/k6 para autenticar e limpar massa
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=Admin@123
