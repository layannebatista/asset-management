# =============================================================================
# Template de variáveis de ambiente
# Copie para .env e preencha com seus valores reais:
#   cp .env.example .env
# =============================================================================

# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5433/asset_management
DB_USERNAME=asset_user
DB_PASSWORD=CHANGE_ME

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_min_64_chars

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=CHANGE_ME@gmail.com

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Vite (build-arg do Docker; URL que o browser usa para chamar a API) ──────
VITE_API_URL=http://localhost:8080

# ─── Grafana (apenas para Docker Compose) ────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
