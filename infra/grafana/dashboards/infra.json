{
  "title": "Patrimonio 360 - Infra Containers",
  "uid": "infra",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "description": "Visao de infraestrutura em nivel de container. Aqui ficam recursos de CPU, memoria, rede e escrita em disco do stack Docker, sem repetir metricas internas da JVM.",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Infraestrutura do stack",
      "type": "row"
    },
    {
      "type": "timeseries",
      "title": "CPU por container",
      "description": "Uso de CPU por container medido pelo cAdvisor. Ideal para identificar qual servico esta consumindo processamento em momentos de pico.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\",image!=\"\"}[2m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 }
    },
    {
      "type": "timeseries",
      "title": "Memoria working set por container",
      "description": "Memoria em uso efetivo por container. Mostra quais servicos estao pressionando RAM e ajuda a ajustar limites no Docker Compose.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{name!=\"\",image!=\"\"}) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 }
    },
    {
      "type": "timeseries",
      "title": "Rede recebida por container",
      "description": "Taxa de recebimento de dados por container. Picos inesperados podem apontar dependencia ruidosa, trafego excessivo ou carga artificial.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\"}[2m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Rede enviada por container",
      "description": "Taxa de envio de dados por container. Complementa o grafico de recebimento e ajuda a detectar servicos que estao respondendo com payload grande demais.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name!=\"\"}[2m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Escrita em disco por container",
      "description": "Bytes gravados por segundo. Valores altos de escrita ajudam a localizar gargalos causados por logs excessivos, filas ou persistencia intensiva.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_fs_writes_bytes_total{name!=\"\",image!=\"\"}[2m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 }
    },
    {
      "type": "stat",
      "title": "Alvo cAdvisor",
      "description": "Status do scrape do cAdvisor. Se cair para zero, os graficos de infraestrutura deixam de refletir o estado real dos containers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(up{job=\"cadvisor\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Offline", "color": "red" },
                "1": { "text": "Online", "color": "green" }
              }
            }
          ],
          "color": { "mode": "background" }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 17 }
    },
    {
      "type": "stat",
      "title": "Containers observados",
      "description": "Quantidade de containers com metricas ativas no cAdvisor. Queda repentina pode indicar container parado ou falha de coleta.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(max by (name) (container_last_seen{name!=\"\",image!=\"\"}))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 17 }
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser"
}
