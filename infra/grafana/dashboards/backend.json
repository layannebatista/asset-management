          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"asset-management\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"asset-management\"}[5m]))",
