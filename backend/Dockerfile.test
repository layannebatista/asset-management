# =============================================================================
# Runner de testes do backend (Maven + H2 em memória)
# Não precisa de banco externo — usa perfil "test" com H2.
# Resultados Allure são escritos em /allure-results (um nível acima do WORKDIR)
# conforme configurado em pom.xml: ${project.basedir}/../allure-results
# =============================================================================
FROM maven:3.9.9-eclipse-temurin-17

WORKDIR /app

# settings-docker.xml redireciona nexus.flywaydb.org (inacessível em containers)
# para o Maven Central, evitando travamento no download de dependências
COPY settings-docker.xml /root/.m2/settings.xml

# Cache de dependências separado do código para aproveitar layer cache
COPY pom.xml .
RUN mvn -B --no-transfer-progress dependency:resolve dependency:resolve-plugins

# Código fonte completo (src/main + src/test)
COPY src ./src

# Script para rodar testes Java + BDD
RUN echo '#!/bin/bash' > /app/run-all-tests.sh && \
    echo 'set -e' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    echo 'echo "Rodando Testes Java (Unit + Integration)..."' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    echo 'mvn test -B --no-transfer-progress -Dallure.results.directory=/allure-results' >> /app/run-all-tests.sh && \
    echo '' >> /app/run-all-tests.sh && \
    echo 'echo ""' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    echo 'echo "Rodando Testes BDD/Cucumber (E2E)..."' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    echo 'mvn test -Dtest=CucumberRunnerTest -B --no-transfer-progress -Dallure.results.directory=/allure-results' >> /app/run-all-tests.sh && \
    echo '' >> /app/run-all-tests.sh && \
    echo 'echo ""' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    echo 'echo "✅ Todos os testes concluídos!"' >> /app/run-all-tests.sh && \
    echo 'echo "=========================================="' >> /app/run-all-tests.sh && \
    chmod +x /app/run-all-tests.sh

CMD ["/app/run-all-tests.sh"]
