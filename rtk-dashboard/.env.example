# ─── AI Intelligence Service ─────────────────────────────────────────────────
AI_SERVICE_PORT=3100
AI_SERVICE_API_KEY=CHANGE_ME_random_secret_key
NODE_ENV=production

# ─── LLM Provider Order / Local Free Mode ───────────────────────────────────
# localfree = deterministic local analysis, no paid key needed
LOCAL_ONLY_MODE=true
LLM_PROVIDER_ORDER=localfree
LOCAL_LLM_ENABLED=true
LOCAL_LLM_MODEL=local-rule-based-v1

# ─── OpenAI (optional fallback) ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.2

# ─── Database (same PostgreSQL instance, ai_intelligence schema) ──────────────
AI_DB_HOST=postgres
AI_DB_PORT=5432
AI_DB_NAME=asset_management
AI_DB_USER=asset_user
AI_DB_PASSWORD=CHANGE_ME

# ─── Internal service URLs ───────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
ALLURE_URL=http://allure:5050
BACKEND_URL=http://asset-management:8080
GRAFANA_URL=http://grafana:3000

# ─── GitHub Actions ──────────────────────────────────────────────────────────
GITHUB_TOKEN=CHANGE_ME
GITHUB_OWNER=CHANGE_ME
GITHUB_REPO=CHANGE_ME

# ─── LLM Cache TTL (seconds) ─────────────────────────────────────────────────
ANALYSIS_CACHE_TTL_SECONDS=300

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
