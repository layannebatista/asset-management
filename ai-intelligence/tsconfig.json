{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "paths": {
      "@config/*": ["./src/config/*"],
      "@types/*": ["./src/types/*"],
      "@analyzers/*": ["./src/analyzers/*"],
      "@collectors/*": ["./src/collectors/*"],
      "@llm/*": ["./src/llm/*"],
      "@context/*": ["./src/context/*"],
      "@orchestrator/*": ["./src/orchestrator/*"],
      "@agents/*": ["./src/agents/*"],
      "@storage/*": ["./src/storage/*"],
      "@api/*": ["./src/api/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
