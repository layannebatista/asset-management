{
  "name": "ai-intelligence",
  "version": "1.0.0",
  "description": "AI Intelligence Layer for Asset Management Platform",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "openai": "^4.67.0",
    "express": "^4.21.0",
    "axios": "^1.7.7",
    "pg": "^8.13.0",
    "zod": "^3.23.8",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "winston": "^3.15.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.10",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "typescript": "^5.6.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.13",
    "ts-jest": "^29.2.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
